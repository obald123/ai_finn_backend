{
  "name": "ai-finance-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for AI Finance Assistant",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "add:admin": "ts-node scripts/addAdminUser.ts",
    "start:all-scripts": "ts-node scripts/addAdminUser.ts && ts-node scripts/insertDataset.ts && ts-node scripts/trainModel.ts && node dist/server.js"
  },
  "keywords": [
    "finance",
    "ai",
    "assistant",
    "typescript",
    "node"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@tensorflow/tfjs": "^4.6.0",
    "@types/express-session": "^1.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/decimal.js": "^0.0.32",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.9",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "bcrypt": "^6.0.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prisma": "^6.7.0",
    "ts-jest": "^29.3.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4"
  }
}
